---
import Layout from '@/layouts/Layout.astro';
import { siteConfig } from '@/lib/ffc-config';
import FFCHomePage from '@/components/ffc-home-page';

const title = `${siteConfig.name} | Candlelight Dinner, Birthday Surprise & Proposals in Surat`;
const description = `Surat's #1 couples-only private celebration venue. Book candlelight dinner, birthday surprise, anniversary, marriage proposal & pre-wedding shoot. Packages from ₹5,100. 4.9★ | 450+ Reviews | 3000+ Couples.`;
---

<Layout title={title} description={description} canonical="https://hivy.co.in/">
  <FFCHomePage client:load />
</Layout>
