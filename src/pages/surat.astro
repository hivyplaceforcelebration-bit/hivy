---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import WhatsAppFloat from '@/components/WhatsAppFloat.astro';
import { siteConfig, packages } from '@/lib/config';

const WA = `https://wa.me/${siteConfig.whatsapp}`;
const WA_MSG = (msg: string) => `${WA}?text=${encodeURIComponent(msg)}`;

const services = [
  {
    emoji: '🕯️', name: 'Candlelight Dinner in Surat',
    slug: 'candlelight-dinner-surat',
    short: 'Private candlelit table setting with floral arrangements, fairy lights and a curated menu — the most romantic candlelight dinner Surat couples swear by.',
    steps: [
      'Choose a date & time that works for you (evenings are most popular)',
      'Pick your package — Swing of Love or Tent of Romance work beautifully for dinner',
      'Share any special requests: cuisine preferences, message board, rose petals',
      'Arrive and find your private space completely set up and ready',
    ],
  },
  {
    emoji: '🎂', name: 'Birthday Surprise in Surat',
    slug: 'birthday-surprise-surat',
    short: 'Surprise your loved one with a fully decorated private birthday setup — balloon arch, personalised message board, cake, fairy lights, and more.',
    steps: [
      'Tell us whose birthday it is and their favourite colours / theme',
      'We secretly set up the entire space before you arrive',
      'Walk in together — their reaction will be priceless',
      'Our team handles the cake, décor and photography if needed',
    ],
  },
  {
    emoji: '💑', name: 'Anniversary Celebration in Surat',
    slug: 'anniversary-surat',
    short: 'Mark your milestone with a premium anniversary celebration Surat setup — roses, candles, personalised signage and a completely private venue just for two.',
    steps: [
      'Share your anniversary date and number of years',
      'Pick a package and any custom add-ons (photo prints, wine, etc.)',
      'We create a romantic setup tailored to your story',
      'Enjoy a fully private, undisturbed celebration',
    ],
  },
  {
    emoji: '💍', name: 'Marriage Proposal in Surat',
    slug: 'proposal-setup-surat',
    short: 'HIVY is Surat\'s most popular venue for marriage proposals. Our Fairy Tale Proposal setup features arch décor, rose petals, fairy lights and a dedicated team to help you plan every detail.',
    steps: [
      'Tell us your proposal vision — intimate or grand',
      'We design the setup: arch, flowers, ring reveal spot, message board',
      'Your partner has no idea what awaits — we keep it a complete surprise',
      'Say the words, she says yes, we capture the moment',
    ],
  },
  {
    emoji: '📸', name: 'Pre-Wedding Shoot in Surat',
    slug: 'pre-wedding-shoot-surat',
    short: 'Our curated pre-wedding shoot setups in Surat provide stunning backdrops — boho, fairy tale, romantic swing — so every frame looks magazine-worthy.',
    steps: [
      'Choose your backdrop theme and colour palette',
      'Schedule a slot during golden hour for best lighting',
      'We set up the full décor — you just show up and be yourselves',
      'Add a professional photographer or bring your own',
    ],
  },
  {
    emoji: '💝', name: 'Surprise Date in Surat',
    slug: 'surprise-date-surat',
    short: 'Plan the ultimate surprise date in Surat — from the décor to the music to the mood. Your partner arrives to a private, magical space crafted just for them.',
    steps: [
      'Tell us about your partner — their favourite things and what surprises them',
      'We plan and set up everything while you keep them guessing',
      'Bring them to the venue at the agreed time',
      'Watch their eyes light up — that\'s the HIVY moment',
    ],
  },
  {
    emoji: '👶', name: 'Baby Moments in Surat',
    slug: 'baby-moments-surat',
    short: 'Baby shower setups, gender reveal decorations and maternity shoot backdrops — all beautifully designed to celebrate new life in Surat.',
    steps: [
      'Share the theme: pink, blue, neutral or your preferred palette',
      'Choose setup type: baby shower, gender reveal or maternity shoot',
      'We handle all the décor, balloon arrangements and signage',
      'Invite your closest family and celebrate this milestone in style',
    ],
  },
  {
    emoji: '❤️', name: "Valentine's Week in Surat",
    slug: 'valentines-week-surat',
    short: 'Celebrate all 7 days of Valentine\'s Week with a fresh romantic experience each day — from Rose Day to Valentine\'s Day, HIVY keeps the love alive.',
    steps: [
      'Plan ahead — Valentine\'s slots fill up by January',
      'Book a different theme for different days of the week',
      'Add surprise elements: chocolates, notes, personalised gifts',
      'We set the mood; you write the love story',
    ],
  },
];

const whyUs = [
  { icon: '🔒', title: '100% Private Venue', desc: 'No strangers, no noise. Every booking gets a fully private space — just you and your loved one, undisturbed.' },
  { icon: '🌹', title: 'Premium Handcrafted Décor', desc: 'Fresh flowers, fairy lights, satin drapes and personalised touches — every setup is built by hand, just for you.' },
  { icon: '⭐', title: '4.9★ Google Rating', desc: 'With 3,000+ couples served and 200+ five-star reviews, HIVY is Surat\'s most trusted romantic celebration venue.' },
  { icon: '⚡', title: 'Instant WhatsApp Booking', desc: 'No long forms or waiting. Chat directly with our team, get a slot confirmed in minutes.' },
  { icon: '🎨', title: 'Fully Customisable', desc: 'Every couple is different. Tell us your vision — theme, colours, message, extras — and we make it real.' },
  { icon: '📍', title: 'Central Adajan Location', desc: 'Easily accessible from every Surat area. Located at The Boulevard, Adajan — just minutes from major landmarks.' },
];

const allSuratAreas = [
  'Adajan', 'Vesu', 'Pal', 'Althan', 'Katargam', 'Varachha', 'Udhna', 'Athwa',
  'Rander', 'Dindoli', 'Piplod', 'Palanpur Patia', 'Bhatar', 'Citylight', 'Sarthana',
  'Sachin', 'Limbayat', 'Amroli', 'Umra', 'Ichchhapor', 'Sagrampura', 'Majura Gate',
  'Ring Road', 'Parvat Patia', 'Khatodara', 'Jahangirpura', 'Ghod Dod Road', 'Magdalla',
  'Dumas Road', 'Nana Varachha', 'Mota Varachha', 'Singanpore', 'Pandesara', 'Salabatpura',
  'Kamrej', 'Kosad', 'Bamroli', 'Mora Bhagal', 'Nanpura', 'Lal Darwaja',
];

const faq = [
  {
    q: 'What is HIVY and where is it located in Surat?',
    a: 'HIVY — Place for Celebrations is Surat\'s premier private celebration venue for couples. We are located at 252/253, 2nd Floor, The Boulevard, Near Pratham Circle, Galleria Street, Adajan, Surat — 394510. We specialise in candlelight dinners, birthday surprises, marriage proposals, anniversary celebrations and more.',
  },
  {
    q: 'What are the package prices at HIVY Surat?',
    a: 'HIVY offers 5 handcrafted celebration packages: Swing of Love (₹5,100), Elite Group Setup (₹5,400), BoHo Chic (₹5,700), Fairy Tale Proposals (₹6,300) and Tent of Romance (₹6,500). All packages include premium décor, candles, a personalised message board and dedicated staff. Food and add-ons can be added.',
  },
  {
    q: 'Is HIVY a couples-only private celebration venue in Surat?',
    a: 'Yes. HIVY is a 100% private celebration venue in Surat designed exclusively for couples and small groups. No other guests are present during your booking slot. You get the entire private space for the duration of your experience.',
  },
  {
    q: 'How do I book a candlelight dinner at HIVY Surat?',
    a: 'Booking is simple — WhatsApp us at +91 97270 27278. Share your occasion, preferred date, time and guest count. Our team confirms your slot within minutes and shares all the details. You can also call us directly for same-day queries.',
  },
  {
    q: 'Can HIVY arrange a marriage proposal setup in Surat?',
    a: 'Absolutely! HIVY is one of Surat\'s most popular venues for marriage proposals. Our Fairy Tale Proposals package (₹6,300) includes arch décor, rose petals, fairy lights and a surprise reveal setup. We\'ve helped hundreds of couples pop the question successfully. Share your vision and we\'ll plan every detail.',
  },
  {
    q: 'How far in advance should I book a romantic dinner at HIVY Surat?',
    a: 'We recommend booking at least 2–3 days in advance, especially for weekends and special occasions like Valentine\'s Day, anniversaries and New Year\'s Eve. For last-minute bookings, WhatsApp us and we\'ll check availability. Popular dates fill up fast.',
  },
  {
    q: 'Does HIVY offer birthday surprise setups in Surat?',
    a: 'Yes! Birthday surprises are one of our most booked services. We create a fully decorated private setup — balloon arch, personalised message board, fairy lights, flowers and cake arrangement — so your loved one walks in to a complete surprise. Tell us the theme and we handle everything.',
  },
  {
    q: 'Does HIVY serve areas outside Adajan in Surat?',
    a: 'Our venue is located in Adajan, but we welcome couples from all 40+ areas of Surat — including Vesu, Pal, Althan, Citylight, Bhatar, Katargam, Varachha, Udhna, Athwa, Rander, Piplod, Sarthana and everywhere in between. Adajan is centrally accessible by cab or auto from all major Surat areas.',
  },
  {
    q: 'Can I customise the decoration at HIVY?',
    a: 'Yes, every setup at HIVY is fully customisable. You can choose your colour scheme, floral arrangements, message board text, music, lighting mood, add-on items and more. Share your ideas with us on WhatsApp before your booking and our team will design a personalised experience just for you.',
  },
  {
    q: 'Does HIVY offer photography for pre-wedding shoots and celebrations?',
    a: 'Yes. We offer professional photography and videography add-ons for pre-wedding shoots, proposals, anniversaries and all celebration setups. Mention it when booking via WhatsApp and we\'ll coordinate the photographer for your session. You can also bring your own photographer — our setups are designed to be photogenic.',
  },
];

const reviews = [
  { name: 'Priya & Darshan', rating: 5, text: 'HIVY made our anniversary celebration so special. The candlelight dinner Surat setup was breathtaking — candles everywhere, fresh roses, personalised board. Cannot recommend enough!', occasion: 'Anniversary' },
  { name: 'Akash Patel', rating: 5, text: 'Booked the Fairy Tale Proposal package and she said YES! The team at HIVY helped me plan every detail. Best marriage proposal setup in Surat, hands down.', occasion: 'Proposal' },
  { name: 'Meera Shah', rating: 5, text: 'Birthday surprise for my husband was exactly as I imagined — actually better. The private celebration venue in Surat is exactly what couples need. No crowd, just us!', occasion: 'Birthday Surprise' },
  { name: 'Ravi & Pooja', rating: 5, text: 'Had our pre-wedding shoot at HIVY with the BoHo Chic setup. Every photo turned out stunning. The team was patient, professional and extremely creative.', occasion: 'Pre-Wedding Shoot' },
  { name: 'Kiran Joshi', rating: 5, text: 'Planned a surprise date for my partner at HIVY Surat. She walked in and was completely blown away. The Swing of Love setup with fairy lights was magical. Thank you HIVY!', occasion: 'Surprise Date' },
  { name: 'Nidhi & Vishal', rating: 5, text: 'Valentine\'s Week was celebrated in the most romantic way at HIVY. Couples only venue in Surat that actually delivers on its promise. Pure privacy, premium décor, perfect evening.', occasion: "Valentine's Week" },
];

const breadcrumbs = [{ name: 'Surat', item: 'https://hivy.co.in/surat' }];

const pageTitle = 'HIVY Surat — Best Private Romantic Celebration Venue | Candlelight Dinner, Proposals & Birthday Surprises';
const pageDesc = 'HIVY is Surat\'s #1 couples-only private celebration venue in Adajan. Book candlelight dinner, marriage proposal, birthday surprise, anniversary & pre-wedding shoot. Packages from ₹5,100. Instant WhatsApp booking. 4.9★ | 3000+ couples served.';

const suratFaqSchema = faq.map(f => ({ question: f.q, answer: f.a }));

const localBusinessSchemaExtra = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "EventVenue", "CafeOrCoffeeShop", "Restaurant", "FoodEstablishment"],
  "@id": "https://hivy.co.in/#business",
  "name": "HIVY — Place for Celebrations",
  "additionalType": [
    "https://schema.org/EventVenue",
    "https://schema.org/CafeOrCoffeeShop",
    "https://schema.org/Restaurant",
    "https://schema.org/Bakery"
  ],
  "keywords": "events venue surat, cafe surat, cake shop surat, restaurant surat, party planner surat, wedding planner surat, photography service surat, fine dining restaurant surat, candlelight dinner surat, birthday surprise surat, anniversary celebration surat, marriage proposal surat, couples only venue surat, private celebration venue surat, romantic dinner surat, pre wedding shoot surat",
  "description": pageDesc,
  "url": "https://hivy.co.in/surat",
  "telephone": "+91 97270 27278",
  "email": "hello@hivy.co.in",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "252/253, 2nd Floor, The Boulevard, Near Pratham Circle, Galleria Street, Green City Road",
    "addressLocality": "Adajan",
    "addressRegion": "Surat, Gujarat",
    "postalCode": "394510",
    "addressCountry": "IN"
  },
  "geo": { "@type": "GeoCoordinates", "latitude": 21.1702, "longitude": 72.8311 },
  "openingHoursSpecification": [{
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
    "opens": "12:00", "closes": "23:00"
  }],
  "priceRange": "₹₹ (₹5,100 – ₹6,500)",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "200",
    "bestRating": "5",
    "worstRating": "1"
  },
  "servesCuisine": "Romantic",
  "amenityFeature": [
    { "@type": "LocationFeatureSpecification", "name": "Private Dining", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Couples Only", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Photography Available", "value": true }
  ],
  "sameAs": [
    "https://www.instagram.com/hivy_placeforcelebration/",
    "https://www.facebook.com/p/Hivy-placeforcelebration-61553052747625/"
  ]
};
---

<Layout
  title={pageTitle}
  description={pageDesc}
  canonical="https://hivy.co.in/surat"
  ogImage="https://hivy.co.in/images/og-home.jpg"
  breadcrumbs={breadcrumbs}
  faqSchema={suratFaqSchema}
>
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchemaExtra)} />

  <Header />
  <WhatsAppFloat />

  <!-- ════════════════════════════════════════════
       GOOGLE BUSINESS PROFILE HERO
  ════════════════════════════════════════════ -->
  <section class="pt-20 pb-0 bg-white border-b border-border">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-xs text-muted py-4" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span class="text-border">/</span>
        <span class="text-foreground font-medium">Surat</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-0 lg:gap-10 pb-0">

        <!-- Left: GBP Card -->
        <div class="lg:col-span-2 pb-8">

          <!-- Open status -->
          <div class="flex items-center gap-2 mb-4">
            <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-green-700 bg-green-50 border border-green-200 px-3 py-1 rounded-full">
              <span class="w-1.5 h-1.5 rounded-full bg-green-500 pulse-dot"></span>
              Open Now · Closes 11 PM
            </span>
          </div>

          <!-- GBP Business Categories (all 10 from profile) -->
          <div class="flex flex-wrap gap-2 mb-5">
            <span class="inline-flex items-center gap-1.5 text-xs font-bold text-white bg-[#4285F4] px-3 py-1.5 rounded-full">
              🏛️ Events Venue
              <span class="text-[9px] bg-white/25 px-1.5 py-0.5 rounded-full tracking-wide">PRIMARY</span>
            </span>
            {[
              { label: 'Cafe', icon: '☕' },
              { label: 'Cake Shop', icon: '🎂' },
              { label: 'Restaurant', icon: '🍽️' },
              { label: 'Party Planner', icon: '🎉' },
              { label: 'Wedding Planner', icon: '💍' },
              { label: 'Live Music Venue', icon: '🎵' },
              { label: 'Photography Service', icon: '📸' },
              { label: 'Fast Food Restaurant', icon: '🥡' },
              { label: 'Fine Dining Restaurant', icon: '🥂' },
            ].map(cat => (
              <span class="inline-flex items-center gap-1 text-xs font-medium text-[#5F6368] bg-[#F8F9FA] border border-[#DADCE0] px-2.5 py-1.5 rounded-full hover:border-[#4285F4] hover:text-[#4285F4] transition-colors cursor-default">
                {cat.icon} {cat.label}
              </span>
            ))}
          </div>

          <!-- Business Name -->
          <h1 class="font-serif text-3xl sm:text-4xl xl:text-5xl font-bold text-foreground leading-tight mb-3">
            HIVY — <span class="gradient-text">Place for Celebrations</span>
          </h1>
          <p class="text-base text-muted font-medium mb-4">Surat's #1 Private Romantic Celebration Venue · Adajan, Surat</p>

          <!-- Rating Row -->
          <div class="flex flex-wrap items-center gap-4 mb-6">
            <div class="flex items-center gap-2">
              <span class="text-2xl font-bold text-foreground">4.9</span>
              <div class="flex text-amber-400 text-lg">★★★★★</div>
              <span class="text-sm text-muted">(200+ Google Reviews)</span>
            </div>
            <div class="h-4 w-px bg-border hidden sm:block"></div>
            <span class="text-sm text-muted">❤️ <strong class="text-foreground">3,000+</strong> Couples Served</span>
            <div class="h-4 w-px bg-border hidden sm:block"></div>
            <span class="text-sm text-muted">📍 <strong class="text-foreground">Adajan</strong>, Surat 394510</span>
          </div>

          <!-- Info Grid (GBP style) -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-6">
            {[
              { icon: '📍', label: 'Address', value: '252/253, 2nd Floor, The Boulevard, Near Pratham Circle, Galleria Street, Adajan, Surat — 394510' },
              { icon: '📞', label: 'Phone', value: '+91 97270 27278' },
              { icon: '🕐', label: 'Hours', value: 'Mon–Sun: 12:00 PM – 11:00 PM' },
              { icon: '💰', label: 'Starting Price', value: '₹5,100 per setup (all-inclusive)' },
            ].map(item => (
              <div class="flex items-start gap-3 bg-surface border border-border rounded-xl px-4 py-3">
                <span class="text-lg flex-shrink-0">{item.icon}</span>
                <div>
                  <p class="text-[10px] font-semibold text-muted uppercase tracking-wider">{item.label}</p>
                  <p class="text-sm text-foreground font-medium leading-snug mt-0.5">{item.value}</p>
                </div>
              </div>
            ))}
          </div>

          <!-- GBP Action Buttons -->
          <div class="flex flex-wrap gap-3 mb-8">
            <a href={WA_MSG('Hi HIVY! I want to book a romantic celebration in Surat. Please share package details.')}
               target="_blank" rel="noopener noreferrer"
               class="flex items-center gap-2 px-5 py-3 bg-green-500 hover:bg-green-600 text-white font-semibold rounded-xl transition-colors shadow-md text-sm">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
              Chat on WhatsApp
            </a>
            <a href="tel:+919727027278"
               class="flex items-center gap-2 px-5 py-3 border-2 border-primary text-primary font-semibold rounded-xl hover:bg-primary/5 transition-colors text-sm">
              📞 Call Now
            </a>
            <a href="https://maps.app.goo.gl/YourGoogleMapsLink"
               target="_blank" rel="noopener noreferrer"
               class="flex items-center gap-2 px-5 py-3 border-2 border-border text-foreground font-semibold rounded-xl hover:border-primary hover:text-primary transition-colors text-sm">
              🗺️ Get Directions
            </a>
            <a href="/"
               class="flex items-center gap-2 px-5 py-3 border-2 border-border text-foreground font-semibold rounded-xl hover:border-primary hover:text-primary transition-colors text-sm">
              🌐 Visit Website
            </a>
          </div>

          <!-- Tags / Keywords — Google-style -->
          <div class="flex flex-wrap gap-2">
            {[
              { label: 'Candlelight Dinner Surat', color: 'bg-blue-50 text-blue-700 border-blue-200' },
              { label: 'Marriage Proposal Surat', color: 'bg-pink-50 text-pink-700 border-pink-200' },
              { label: 'Birthday Surprise Surat', color: 'bg-amber-50 text-amber-700 border-amber-200' },
              { label: 'Anniversary Celebration Surat', color: 'bg-rose-50 text-rose-700 border-rose-200' },
              { label: 'Couples Only Venue Surat', color: 'bg-purple-50 text-purple-700 border-purple-200' },
              { label: 'Private Celebration Venue Surat', color: 'bg-green-50 text-green-700 border-green-200' },
              { label: 'Romantic Dinner Surat', color: 'bg-red-50 text-red-700 border-red-200' },
              { label: 'Pre-Wedding Shoot Surat', color: 'bg-indigo-50 text-indigo-700 border-indigo-200' },
              { label: 'Party Planner Surat', color: 'bg-orange-50 text-orange-700 border-orange-200' },
              { label: 'Wedding Planner Surat', color: 'bg-fuchsia-50 text-fuchsia-700 border-fuchsia-200' },
              { label: 'Fine Dining Surat', color: 'bg-teal-50 text-teal-700 border-teal-200' },
              { label: 'Photography Service Surat', color: 'bg-cyan-50 text-cyan-700 border-cyan-200' },
            ].map(tag => (
              <span class={`text-xs border px-2.5 py-1 rounded-full font-medium ${tag.color}`}>{tag.label}</span>
            ))}
          </div>
        </div>

        <!-- Right: Photo Grid (GBP style) -->
        <div class="hidden lg:block lg:col-span-1">
          <div class="grid grid-cols-2 gap-2 h-full max-h-[440px]">
            <div class="col-span-2 rounded-2xl bg-gradient-to-br from-amber-100 to-rose-100 border border-border flex items-center justify-center text-5xl" style="height:200px;">🕯️</div>
            <div class="rounded-xl bg-gradient-to-br from-pink-50 to-rose-100 border border-border flex items-center justify-center text-3xl" style="height:116px;">💍</div>
            <div class="rounded-xl bg-gradient-to-br from-amber-50 to-orange-100 border border-border flex items-center justify-center text-3xl" style="height:116px;">🎂</div>
            <div class="rounded-xl bg-gradient-to-br from-rose-50 to-pink-100 border border-border flex items-center justify-center text-3xl" style="height:116px;">🌹</div>
            <div class="rounded-xl bg-gradient-to-br from-stone-100 to-amber-100 border border-border flex items-center justify-center text-3xl" style="height:116px;">📸</div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════
       GOOGLE MAPS EMBED
  ════════════════════════════════════════════ -->
  <section class="bg-white border-b border-border">
