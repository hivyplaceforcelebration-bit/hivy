---
import Layout from '@/layouts/Layout.astro';
import FFCServicePage from '@/components/ffc-service-page';
import { serviceCategories } from '@/lib/ffc-config';

export function getStaticPaths() {
  return serviceCategories.map(svc => ({
    params: { slug: svc.slug },
    props: { svc },
  }));
}

const { svc } = Astro.props;
---

<Layout
  title={svc.metaTitle}
  description={svc.metaDescription}
  canonical={`https://hivy.co.in/services/${svc.slug}`}
>
  <FFCServicePage client:load service={svc} />
</Layout>
