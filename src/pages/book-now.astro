---
import Layout from '@/layouts/Layout.astro';
import { FFCHeader, FFCFooter } from '@/components/ffc-layout';
import { FFCBookingForm } from '@/components/ffc-booking-form';
---
<Layout title="Book Now — HIVY Surat | Reserve Your Romantic Celebration" description="Book your romantic celebration at HIVY Surat. Fill in the form and we'll confirm instantly via WhatsApp. Packages from ₹5,100." canonical="https://hivy.co.in/book-now">
  <FFCHeader client:load />
  <main class="container mx-auto px-4 py-20 max-w-xl">
    <h1 class="text-3xl font-bold text-center mb-3 text-amber-900">Reserve Your Moment</h1>
    <p class="text-center text-gray-600 mb-8">Fill in the details below — we'll confirm your booking instantly on WhatsApp.</p>
    <FFCBookingForm client:load variant="default" />
  </main>
  <FFCFooter client:load />
</Layout>
