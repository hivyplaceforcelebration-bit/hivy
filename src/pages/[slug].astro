---
import Layout from '@/layouts/Layout.astro';
import FFCKeywordPage from '@/components/ffc-keyword-page';
import FFCAreaPage from '@/components/ffc-area-page';
import {
  suratAreas, serviceCategories, getAreaBySlug,
  type AreaConfig, type ServiceCategory, type ServiceKeyword
} from '@/lib/ffc-config';
import { getAllExpandedKeywordSlugs, getExpandedKeywordBySlug, type ExpandedKeyword } from '@/lib/expanded-keywords';

export async function getStaticPaths() {
  const paths: any[] = [];

  // 1. Area pages: /adajan-surat etc.
  suratAreas.forEach(area => {
    paths.push({
      params: { slug: area.slug },
      props: { pageType: 'area', area, keyword: null, service: null, expandedKeyword: null },
    });
  });

  // 2. Service keyword pages from ffc-config
  serviceCategories.forEach(svc => {
    svc.keywords.forEach(kw => {
      paths.push({
        params: { slug: kw.slug },
        props: { pageType: 'keyword', area: null, keyword: kw, service: svc, expandedKeyword: null },
      });
    });
  });

  // 3. Expanded keywords (3000+)
  const expandedSlugs = getAllExpandedKeywordSlugs();
  expandedSlugs.forEach(slug => {
    const kw = getExpandedKeywordBySlug(slug);
    if (kw) {
      // Find the matching service for cross-linking
      const matchedService = serviceCategories.find(s => s.slug === kw.category)
        || serviceCategories[0];
      // Create a fake ServiceKeyword for the expanded keyword
      const fakeKw: ServiceKeyword = {
        slug: kw.slug,
        title: kw.title,
        h1: kw.h1,
        metaTitle: kw.metaTitle,
        metaDescription: kw.metaDescription,
      };
      paths.push({
        params: { slug },
        props: {
          pageType: 'keyword',
          area: null,
          keyword: fakeKw,
          service: matchedService,
          expandedKeyword: kw,
        },
      });
    }
  });

  return paths;
}

type Props = {
  pageType: 'area' | 'keyword';
  area: AreaConfig | null;
  keyword: ServiceKeyword | null;
  service: ServiceCategory | null;
  expandedKeyword: ExpandedKeyword | null;
};

const { pageType, area, keyword, service, expandedKeyword } = Astro.props;
const slug = Astro.params.slug as string;

let title = '';
let description = '';
const canonical = `https://hivy.co.in/${slug}`;

if (pageType === 'area' && area) {
  title = `Romantic Celebration & Candlelight Dinner in ${area.name}, Surat — HIVY`;
  description = `Looking for a romantic venue near ${area.name}, Surat? HIVY offers candlelight dinners, birthday surprises, proposals & anniversary setups near ${area.name}. Packages from ₹5,100.`;
} else if (keyword) {
  title = keyword.metaTitle;
  description = keyword.metaDescription;
}
---

<Layout title={title} description={description} canonical={canonical}>
  {pageType === 'area' && area && (
    <FFCAreaPage client:load area={area} />
  )}
  {pageType === 'keyword' && keyword && service && (
    <FFCKeywordPage client:load service={service} keyword={keyword} />
  )}
</Layout>
